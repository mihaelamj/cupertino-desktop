    "key.unit.moduleNamePrefixForClasses.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Derived class-name prefix"
          }
        }
      }
    },
    "keyword.directory.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "`directory \"<path>\"` declares a directory that must exist in the produced bundle even though no file implies it."
          }
        }
      }
    },
    "keyword.directory.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An explicitly created empty directory"
          }
        }
      }
    },
    "keyword.let.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "`let Key = value` inside any block sets one key of that block's dictionary: template level = TemplateInfo top-level key, option level = option key, node level = definition key. Keys are unreserved; any plist key name is legal."
          }
        }
      }
    },
    "keyword.let.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Binds one manifest key to a value"
          }
        }
      }
    },
    "keyword.node.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "`node \"<path>\" { ... }` declares an emitted file. Bindings inside are its definition: `content` (the body, macros included), `binary` (base64 payload), or a `Path` redirect. A node without content here is an insertion slot or ancestor-provided file."
          }
        }
      }
    },
    "keyword.node.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One produced file (or insertion) and its definition"
          }
        }
      }
    },
    "keyword.option.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "`option \"<identifier>\" { ... }` declares one entry of the `Options` array: a control real Xcode renders on the \"Choose options\" sheet and waits on. Its `Type`, `Name`, `Default`, and `Values` bindings shape the widget; its units realize the chosen value."
          }
        }
      }
    },
    "keyword.option.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One user-facing control on the options form"
          }
        }
      }
    },
    "keyword.template.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The root construct. `template \"<identifier>\" { ... }` carries the bundle's manifest as let bindings plus its options, nodes, and directories. The string is the manifest `Identifier` (may be empty; the `Name` binding then drives the bundle folder name)."
          }
        }
      }
    },
    "keyword.template.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Declares the whole template bundle"
          }
        }
      }
    },
    "keyword.unit.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "`unit \"<value>\" { ... }` inside an option declares what choosing `<value>` contributes: nodes to emit and definitions to merge. This is the structural road from a dialog choice to files on disk."
          }
        }
      }
    },
    "keyword.unit.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The consequence of one option value"
          }
        }
      }
    },
