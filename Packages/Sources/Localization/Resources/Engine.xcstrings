      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unit-scope derived variable: the prefix prepended to generated class names for this option value (referenced as `___VARIABLE_moduleNamePrefixForClasses___`)."
          }
        }
      }
